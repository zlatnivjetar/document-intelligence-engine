{
  "name": "@docpipe/cli",
  "version": "0.1.0",
  "description": "DocPipe CLI — extract structured data from documents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "docpipe": "./dist/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "node ../../scripts/prepare-cli-package.mjs prepack",
    "postpack": "node ../../scripts/prepare-cli-package.mjs postpack"
  },
  "dependencies": {
    "@docpipe/core": "workspace:0.1.0",
    "commander": "^13.0.0",
    "jiti": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
