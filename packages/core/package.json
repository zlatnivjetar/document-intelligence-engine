{
  "name": "@docpipe/core",
  "version": "0.1.0",
  "description": "Document intelligence extraction engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ai": "^6.0.140",
    "@ai-sdk/anthropic": "^3.0.64",
    "@anthropic-ai/sdk": "^0.80.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "latest",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "zod": "^4.3.6",
    "ai": "^6.0.140"
  }
}
